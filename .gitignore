# ========================================
# FCM363X Zephyr Workspace Gitignore
# ========================================

# ----------------------------------------
# Submodules (managed by Git)
# ----------------------------------------
# fcm363x-board and fcm363x-examples are submodules
# Their contents are tracked by .gitmodules

# ----------------------------------------
# Tools (cloned from external repos)
# ----------------------------------------
/tools/rw61x-blhost-helper/
/tools/jlink_patch/

# Keep tools directory
!/tools/.gitkeep

# ----------------------------------------
# West-managed SDK
# ----------------------------------------
/nxp-zsdk/
/.west/

# ----------------------------------------
# Python
# ----------------------------------------
/.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-log.txt
pip-delete-this-directory.txt

# ----------------------------------------
# Build outputs
# ----------------------------------------
build/
*.bin
*.hex
*.elf
*.map
*.log

# ----------------------------------------
# IDE
# ----------------------------------------
# Keep project-level VSCode settings
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ----------------------------------------
# OS
# ----------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ----------------------------------------
# Archives
# ----------------------------------------
/archives/
/logs/
